DATABASE_URL="postgresql://jobsfinder:jobsfinder@localhost:5433/jobsfinder?schema=public"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Local uploads (paths stored in DB, files under backend/images/)
UPLOAD_ROOT=./images
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_PUBLIC_BASE_URL=http://localhost:4000

# Default admin (after npm run prisma:seed): admin@jobsfinder.lk / Password123!
