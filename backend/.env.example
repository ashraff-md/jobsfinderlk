DATABASE_URL="postgresql://jobsfinder:jobsfinder@localhost:5433/jobsfinder?schema=public"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# Email verification (SendGrid). Without this, links are logged to the server console.
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@jobsfinder.lk

# Phone OTP (Twilio). Without this, OTP codes are logged to the server console.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Local uploads (paths stored in DB, files under backend/images/)
UPLOAD_ROOT=./images
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_PUBLIC_BASE_URL=http://localhost:4000

# Default admin (after npm run prisma:seed): admin@jobsfinder.lk / Password123!
