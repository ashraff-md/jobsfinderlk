generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SEEKER
  EMPLOYER
  ADMIN
  MODERATOR
}

enum JobStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  CLOSED
  EXPIRED
}

enum CompanyRequestStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}

enum BannerAspectRatio {
  RATIO_3_2
  RATIO_2_5
}

enum PlatformAdReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationTokenType {
  EMAIL
  PHONE
}

enum EmployerPurchaseProduct {
  JOB_LISTINGS
  SPONSORED_JOBS
  BANNER_ADVERTISING
}

enum PromoDiscountType {
  PERCENT
  FIXED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(SEEKER)
  emailVerified Boolean   @default(false) @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  seekerProfile SeekerProfile?
  adminProfile  AdminProfile?
  employerUsers EmployerUser[]
  applications  Application[]
  companyRequests CompanyRequest[]
  reviewedJobs  Job[] @relation("JobReviewedBy")
  postedJobs    Job[] @relation("JobPostedBy")
  reviewedCompanyRequests CompanyRequest[] @relation("CompanyRequestReviewedBy")
  reviewedById  String?   @map("reviewed_by_id")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewedBy    User?     @relation("RecruiterReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  moderatedRecruiters User[] @relation("RecruiterReviewedBy")
  verificationTokens VerificationToken[]
  createdGovernmentOrganizations GovernmentOrganization[] @relation("GovOrgCreatedBy")
  employerPurchases EmployerPurchase[]
  submittedBannerCampaigns PlatformBannerCampaign[] @relation("BannerCampaignSubmittedBy")
  submittedSponsoredAds      SponsoredAd[]           @relation("SponsoredAdSubmittedBy")

  @@map("users")
}

model PromoCode {
  id            String                  @id @default(uuid())
  code          String                  @unique
  description   String?
  discountType  PromoDiscountType       @map("discount_type")
  discountValue Int                     @map("discount_value")
  minSubtotal   Int                     @default(0) @map("min_subtotal")
  maxUses       Int?                    @map("max_uses")
  usedCount     Int                     @default(0) @map("used_count")
  active        Boolean                 @default(true)
  startsAt      DateTime?               @map("starts_at")
  endsAt        DateTime?               @map("ends_at")
  products      EmployerPurchaseProduct[] @default([])
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  purchases EmployerPurchase[]

  @@map("promo_codes")
}

model EmployerPurchase {
  id            String                  @id @default(uuid())
  userId        String                  @map("user_id")
  product       EmployerPurchaseProduct
  plan          String
  duration      String?
  jobSlots      Int?                    @map("job_slots")
  subtotal      Int?
  promoCodeId   String?                 @map("promo_code_id")
  promoCode     String?                 @map("promo_code")
  promoDiscount Int                     @default(0) @map("promo_discount")
  total         Int
  paymentMethod String                  @map("payment_method")
  purchasedAt   DateTime                @default(now()) @map("purchased_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCodeRef PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([userId, purchasedAt])
  @@map("employer_purchases")
}

model AdminProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  email     String?
  contactNo String?  @map("contact_no")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model SeekerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  fullName  String?  @map("full_name")
  headline  String?
  resumeUrl String?  @map("resume_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seeker_profiles")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  website     String?
  description String?
  logoUrl     String?  @map("logo_url")
  industry    String?
  address     String?
  city        String?
  location    String?
  companyType String?  @map("company_type")
  emailDomain String?  @map("email_domain")
  verified    Boolean  @default(false)
  lifeAtCompanyImages String[] @default([]) @map("life_at_company_images")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employerUsers   EmployerUser[]
  jobs            Job[]
  mergedRequests     CompanyRequest[] @relation("CompanyRequestMerged")
  placeholderRequest CompanyRequest?  @relation("CompanyRequestPlaceholder")

  @@map("companies")
}

model EmployerUser {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  companyId       String    @map("company_id")
  fullName        String?   @map("full_name")
  title           String?
  contactNo       String?   @map("contact_no")
  photoUrl        String?   @map("photo_url")
  phoneVerified   Boolean   @default(false) @map("phone_verified")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("employer_users")
}

model VerificationToken {
  id        String                @id @default(uuid())
  userId    String                @map("user_id")
  type      VerificationTokenType
  target    String
  codeHash  String                @map("code_hash")
  expiresAt DateTime              @map("expires_at")
  createdAt DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("verification_tokens")
}

model CompanyRequest {
  id            String               @id @default(uuid())
  companyName   String               @map("company_name")
  industry      String?
  website       String?
  emailDomain   String?              @map("email_domain")
  address       String?
  city          String?
  location      String?
  companyType   String?              @map("company_type")
  description   String?
  logoUrl       String?              @map("logo_url")
  lifeAtCompanyImages String[]       @default([]) @map("life_at_company_images")
  requestedById String               @map("requested_by")
  status               CompanyRequestStatus @default(PENDING)
  placeholderCompanyId String?              @unique @map("placeholder_company_id")
  mergedIntoId         String?              @map("merged_into_id")
  reviewNotes            String?              @map("review_notes")
  reviewedById           String?              @map("reviewed_by_id")
  reviewedAt             DateTime?            @map("reviewed_at")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  requestedBy        User     @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  placeholderCompany Company? @relation("CompanyRequestPlaceholder", fields: [placeholderCompanyId], references: [id], onDelete: SetNull)
  mergedInto         Company? @relation("CompanyRequestMerged", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  reviewedBy         User?    @relation("CompanyRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("company_requests")
}

model PlatformPartner {
  id          String   @id @default(uuid())
  name        String
  screenText  String?  @map("screen_text")
  website     String?
  sortOrder   Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_partners")
}

model GovernmentOrganization {
  id                   String   @id @default(uuid())
  name                 String
  slug                 String   @unique
  organizationType     String   @map("organization_type")
  parentOrganizationId String?  @map("parent_organization_id")
  shortName            String?  @map("short_name")
  description          String?
  website              String?
  email                String?
  contactNumber        String?  @map("contact_number")
  headOfficeAddress    String?  @map("head_office_address")
  district             String?
  province             String?
  logoUrl              String?  @map("logo_url")
  createdById          String?  @map("created_by_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  parent    GovernmentOrganization?  @relation("GovOrgHierarchy", fields: [parentOrganizationId], references: [id], onDelete: SetNull)
  children  GovernmentOrganization[] @relation("GovOrgHierarchy")
  createdBy User?                    @relation("GovOrgCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  jobs      Job[]

  @@index([name])
  @@map("government_organizations")
}

model JobCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String   @default("work")
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("job_categories")
}

model Job {
  id                   String    @id @default(uuid())
  companyId            String    @map("company_id")
  title                String
  slug                 String    @unique
  description          String
  responsibilities     String?
  requirements         String?
  location             String?
  city                 String?
  salaryMin            Int?      @map("salary_min")
  salaryMax            Int?      @map("salary_max")
  salaryType           String?   @map("salary_type")
  salaryCurrency       String?   @default("LKR") @map("salary_currency")
  employmentType       String?   @map("employment_type")
  workArrangement      String?   @map("work_arrangement")
  experienceLevel      String?   @map("experience_level")
  educationRequirement String?   @map("education_requirement")
  ageMin               Int?      @map("age_min")
  ageMax               Int?      @map("age_max")
  industry             String?
  category             String?
  sector               String?
  positionsCount       Int?      @map("positions_count")
  requiredSkills       String[]  @default([]) @map("required_skills")
  niceToHaveSkills     String[]  @default([]) @map("nice_to_have_skills")
  keywords             String[]  @default([])
  recruiterRole        String?   @map("recruiter_role")
  requestedCompanyName String?   @map("requested_company_name")
  governmentOrganizationId String? @map("government_organization_id")
  applicationDeadline  DateTime? @map("application_deadline")
  applyViaEmail        Boolean   @default(false) @map("apply_via_email")
  applyViaExternalLink Boolean   @default(false) @map("apply_via_external_link")
  applyViaWalkIn       Boolean   @default(false) @map("apply_via_walk_in")
  applyViaRegisteredPost Boolean @default(false) @map("apply_via_registered_post")
  applyViaOneClick     Boolean   @default(true) @map("apply_via_one_click")
  applicationEmail     String?   @map("application_email")
  applicationExternalUrl String? @map("application_external_url")
  walkInDetails        String?   @map("walk_in_details")
  registeredPostDetails String?  @map("registered_post_details")
  jobDocumentUrl       String?   @map("job_document_url")
  vacancyArtworkUrl    String?   @map("vacancy_artwork_url")
  jobSourceType        String?   @default("DIRECT_EMPLOYER") @map("job_source_type")
  verificationLevel    String?   @map("verification_level")
  status               JobStatus @default(DRAFT)
  isFeatured           Boolean   @default(false) @map("is_featured")
  viewCount            Int       @default(0) @map("view_count")
  publishedAt          DateTime? @map("published_at")
  expiresAt            DateTime? @map("expires_at")
  reviewedById         String?   @map("reviewed_by_id")
  reviewedAt           DateTime? @map("reviewed_at")
  postedById           String?   @map("posted_by_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  governmentOrganization GovernmentOrganization? @relation(fields: [governmentOrganizationId], references: [id], onDelete: SetNull)
  reviewedBy             User?                   @relation("JobReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  postedBy               User?                   @relation("JobPostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  applications             Application[]
  sponsoredAd              SponsoredAd?

  @@map("jobs")
}

model Application {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  jobId     String   @map("job_id")
  status    String   @default("submitted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("applications")
}

model PlatformBannerSlot {
  id          String            @id @default(uuid())
  key         String            @unique
  label       String
  aspectRatio BannerAspectRatio @map("aspect_ratio")
  active      Boolean           @default(true)
  startsAt    DateTime          @map("starts_at")
  endsAt      DateTime          @map("ends_at")
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  slides PlatformBannerSlide[]

  @@map("platform_banner_slots")
}

model PlatformBannerSlide {
  id        String   @id @default(uuid())
  slotId    String   @map("slot_id")
  href      String   @default("/jobs")
  imageUrl  String?  @map("image_url")
  alt       String   @default("")
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slot PlatformBannerSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@map("platform_banner_slides")
}

model PlatformBannerCampaign {
  id             String                 @id @default(uuid())
  label          String
  aspectRatio    BannerAspectRatio      @map("aspect_ratio")
  href           String                 @default("/jobs")
  imageUrl       String?                @map("image_url")
  alt            String                 @default("")
  active         Boolean                @default(true)
  reviewStatus   PlatformAdReviewStatus @default(APPROVED) @map("review_status")
  reviewNotes    String?                @map("review_notes")
  submittedById  String?                @map("submitted_by_id")
  promotionDays  Int                    @default(7) @map("promotion_days")
  startsAt       DateTime               @map("starts_at")
  endsAt         DateTime               @map("ends_at")
  sortOrder      Int                    @default(0) @map("sort_order")
  viewCount      Int                    @default(0) @map("view_count")
  clickCount     Int                    @default(0) @map("click_count")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  submittedBy User? @relation("BannerCampaignSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)

  @@index([submittedById, createdAt])
  @@map("platform_banner_campaigns")
}

model SponsoredAd {
  id            String                 @id @default(uuid())
  jobId         String                 @unique @map("job_id")
  sortOrder     Int                    @default(0) @map("sort_order")
  active        Boolean                @default(true)
  reviewStatus  PlatformAdReviewStatus @default(APPROVED) @map("review_status")
  reviewNotes   String?                @map("review_notes")
  submittedById String?                @map("submitted_by_id")
  promotionDays Int                    @default(7) @map("promotion_days")
  startsAt      DateTime               @map("starts_at")
  endsAt        DateTime               @map("ends_at")
  viewCount     Int                    @default(0) @map("view_count")
  clickCount    Int                    @default(0) @map("click_count")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  job         Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submittedBy User? @relation("SponsoredAdSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)

  @@index([submittedById, createdAt])
  @@map("sponsored_ads")
}
